# View original source and credit: https://github.com/Tupu4545/WakeOnLan
#
# ── Failover ──
# FAILOVER_ENABLED: Set to "yes" to enable high-availability active/passive failover.
# PRIMARY_DEVICE: "yes" if this is the primary node, "no" if backup
# If yes: set SECONDARY_IP to the backup node's IP
# If no: set PRIMARY_IP to the primary node's IP
# Node roles are derived from this automatically.
FAILOVER_ENABLED=yes
PRIMARY_DEVICE=yes
SECONDARY_IP=
PRIMARY_IP=
HEARTBEAT_PORT=12345
MONITOR_INTERVAL=30

# ── Telegram ──
# Leave TELEGRAM_BOT_TOKEN blank to gracefully disable the Telegram bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_AUTHORIZED_USERS=
# Multiple user IDs separated by commas: 123456789,987654321

# ── Discord ──
# Leave DISCORD_BOT_TOKEN blank to gracefully disable the Discord bot
DISCORD_BOT_TOKEN=
DISCORD_AUTHORIZED_USERS=
# If DISCORD_CHANNEL_ID is blank, bot will only DM authorized users
# If set, bot will also post to the channel globally
DISCORD_CHANNEL_ID=

# ── Proxy Configuration ──
# PROXY_ENABLED: "yes" to route Telegram/Discord bot traffic through the specified proxy
PROXY_ENABLED=no
# PROXY_URL: SOCKS5 or HTTP/HTTPS proxy URL. Supports credentials if required.
# Examples:
#   SOCKS5: socks5://127.0.0.1:1080
#   SOCKS5 with Auth: socks5://username:password@127.0.0.1:1080
#   HTTP/HTTPS: http://127.0.0.1:3128
#   HTTP with Auth: http://username:password@127.0.0.1:3128
PROXY_URL=socks5://127.0.0.1:1080

# PROXY_ONLY: "yes" to fail immediately if proxy is unreachable. "no" to fallback to direct connection.
PROXY_ONLY=no

# HEARTBEAT_SECRET: Authentication secret for failover synchronization.
# If configured, requests to sync config files on the primary node must include this secret.
HEARTBEAT_SECRET=

# ── Email Alerts (SMTP) ──
# EMAIL_ALERTS_ENABLED: "yes" to enable SMTP email alerts for critical bot/device failures.
EMAIL_ALERTS_ENABLED=no
EMAIL_SMTP_SERVER=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_SENDER=
EMAIL_RECEIVER=
# SMTP credentials (use Gmail App Password or Brevo SMTP key)
EMAIL_SMTP_PASSWORD=