# ── Failover ──
# FAILOVER_ENABLED: Set to "yes" to enable high-availability active/passive failover.
# PRIMARY_DEVICE: "yes" if this is the primary node, "no" if backup
# If yes: set SECONDARY_IP to the backup node's IP
# If no: set PRIMARY_IP to the primary node's IP
# Node roles are derived from this automatically.
FAILOVER_ENABLED=yes
PRIMARY_DEVICE=yes
SECONDARY_IP=
PRIMARY_IP=
HEARTBEAT_PORT=12345
MONITOR_INTERVAL=30

# ── Telegram ──
# Leave TELEGRAM_BOT_TOKEN blank to gracefully disable the Telegram bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_AUTHORIZED_USERS=
# Multiple user IDs separated by commas: 123456789,987654321

# ── Discord ──
# Leave DISCORD_BOT_TOKEN blank to gracefully disable the Discord bot
DISCORD_BOT_TOKEN=
DISCORD_AUTHORIZED_USERS=
# If DISCORD_CHANNEL_ID is blank, bot will only DM authorized users
# If set, bot will also post to the channel globally
DISCORD_CHANNEL_ID=